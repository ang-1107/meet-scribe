# Meet Scribe — Environment Variables (secrets only)
# All non-secret configuration is in config.yaml.

# AI Summarization — at least one key recommended.
GEMINI_API_KEY=
OPENAI_API_KEY=

# Firebase client config (browser) for sign-in.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firebase Admin config (server). Use ONE method below.

# Method A: full JSON string from service-account file.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Method B: split fields.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Optional alternative to FIREBASE_PRIVATE_KEY: base64-encoded key string.
FIREBASE_PRIVATE_KEY_BASE64=

# Optional: allow DEV:<id> tokens in non-production environments.
FIREBASE_ALLOW_DEV_AUTH=true