GEMINI_API_KEY=
OPENAI_API_KEY=

# When true, backend skips Playwright and uses demo transcript generation.
MEETSCRIBE_FORCE_SIMULATION=false

# When true, if real Meet join/capture fails, app falls back to simulation transcript.
MEETSCRIBE_ALLOW_SIMULATION_FALLBACK=false

# When true, Playwright launches headless. For local debugging and stricter anti-bot surfaces, false is often better.
MEETSCRIBE_HEADLESS=false

# Optional: default bot display name and listen duration (seconds)
MEETSCRIBE_DEFAULT_BOT_NAME=Meet Scribe Bot
MEETSCRIBE_DEFAULT_DURATION_SECONDS=300

# Optional: custom path for persistent Chrome profile (Google login cookies).
# Defaults to data/chrome-profile/ relative to project root.
# For deployment, set this to a writable directory on the host.
MEETSCRIBE_CHROME_PROFILE_DIR=